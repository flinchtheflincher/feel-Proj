{
  "manifest_version": 3,
  "name": "Mini Context Window",
  "description": "Open a mini context box on LLM sites to ask side questions without breaking your main conversation flow.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:11434/*"
  ],
  "action": {
    "default_title": "Mini Context"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-mini-context": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Toggle mini context window"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}